# ============================================
# Blazion Forms — Environment Variables
# Copy to .env and fill in your values
# ============================================

# ── Database ──
DATABASE_URL=postgresql://blazion:PASSWORD@localhost:5432/blazion

# ── Authentication ──
JWT_SECRET=generate-a-64-char-random-string
JWT_REFRESH_SECRET=generate-another-64-char-random-string
FRONTEND_URL=https://blazionforms.com

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Email (Resend) ──
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Stripe Billing ──
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ── File Storage (Cloudflare R2) ──
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=blazion-uploads
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Monitoring ──
SENTRY_DSN=
MONITOR_SLACK_WEBHOOK=

# ── Deployment ──
NODE_ENV=production
PORT=4000

# ── Database Backups ──
BACKUP_S3_BUCKET=blazion-backups
POSTGRES_USER=blazion
POSTGRES_PASSWORD=your-secure-password
POSTGRES_HOST=localhost
